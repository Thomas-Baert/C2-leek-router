# --- IDE & OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Build & Output ---
# On ignore tout le dossier build où CMake et Conan travaillent
build/
bin/
lib/
out/

# Fichiers de log de compilation
*.log
*.tlog

# --- Conan ---
# Si tu n'utilises pas build/ comme dossier de sortie, conan génère parfois ces fichiers à la racine
conan.lock
conanfile.pyc
.conan/

# --- CMake ---
# Au cas où tu aurais lancé cmake par erreur à la racine au lieu de build/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Testing/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CMakePresets.json
# Note : Certains préfèrent garder CMakePresets.json, mais avec Conan 
# il est souvent généré dynamiquement dans le dossier build.

# --- C++ Objects & Binaries ---
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.lib
*.pdb
*.ilk
*.exp

# --- Divers ---
.cache/
.ninja_deps
.ninja_log
.clangd